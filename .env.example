# ─────────────────────────────────────────────────────────────
# THE ILLUSION — Environment Variables
# Copy this file to ".env.local" and fill in real values.
# NEVER commit .env.local. The NEXT_PUBLIC_ ones are safe in the
# browser; SUPABASE_SERVICE_ROLE_KEY is SERVER-ONLY and secret.
# ─────────────────────────────────────────────────────────────

# From Supabase → Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=

# From Supabase → Project Settings → API → anon public key
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# From Supabase → Project Settings → API → service_role key (SECRET!)
SUPABASE_SERVICE_ROLE_KEY=

# The public URL of the site (used for SEO/OG). Local: http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Email notifications (Resend) ──
# From resend.com → API Keys
RESEND_API_KEY=
# Where YOU receive new-order alerts
ADMIN_EMAIL=shreeharikemvmcbe@gmail.com
# Sender address (test default works; use your domain later)
EMAIL_FROM=THE ILLUSION <onboarding@resend.dev>
